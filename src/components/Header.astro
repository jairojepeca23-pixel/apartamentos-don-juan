---

<header class="cabecera">
  <div class="contenedor cabecera__interior">
    <a class="cabecera__marca" href="/">Apartamentos de Don Juan</a>
    <nav aria-label="Navegación principal">
      <ul class="cabecera__menu">
        <li><a href="/#apartamentos">Apartamentos</a></li>
        <li><a href="/#servicios">Equipamiento</a></li>
        <li><a href="/#sobre">El pueblo</a></li>
        <li><a href="/#contacto">Contacto</a></li>
        <li>
          <a class="cabecera__tel" href="tel:+34677256036">
            +34 677 25 60 36
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .cabecera {
    position: absolute;
    inset-inline: 0;
    top: 0;
    z-index: 10;
    padding-block: 1.2rem;
    color: var(--claro);
  }

  .cabecera__interior {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .cabecera__marca {
    font-family: var(--fuente-display);
    font-size: 1.35rem;
    text-decoration: none;
  }

  .cabecera__menu {
    display: flex;
    gap: 1.6rem;
    list-style: none;
    padding: 0;
    align-items: center;
    flex-wrap: wrap;
  }

  .cabecera__menu a {
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    opacity: 0.9;
  }

  .cabecera__menu a:hover,
  .cabecera__menu a:focus-visible {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-color: var(--acento);
  }

  .cabecera__tel {
    font-weight: 700;
    color: var(--acento);
  }

  @media (max-width: 640px) {
    .cabecera__menu {
      gap: 1rem;
      font-size: 0.9rem;
    }
  }
</style>
