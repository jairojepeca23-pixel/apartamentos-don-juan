---
import { SITE } from "../data/site";
---

<section id="inicio" class="hero">
  <div class="contenedor hero__interior">
    <p class="antetitulo">{SITE.hero.antetitulo}</p>
    <h1 class="hero__titulo">{SITE.hero.titulo}</h1>
    <p class="hero__texto">
      {SITE.hero.texto}
    </p>
    <div class="hero__acciones">
      <a class="boton boton--acento" href={SITE.contacto.whatsapp}>
        {SITE.hero.ctaPrimario}
      </a>
      <a class="boton boton--fantasma" href="#apartamentos">
        {SITE.hero.ctaSecundario}
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--primario);
    background-image: repeating-linear-gradient(
      100deg,
      transparent 0 22px,
      rgb(255 255 255 / 0.02) 22px 23px
    );
    color: var(--claro);
    min-height: 88vh;
    display: grid;
    align-items: center;
    padding-block: 8rem 5rem;
  }

  .hero__interior {
    max-width: var(--ancho-max);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  .hero__titulo {
    font-size: clamp(2.4rem, 6.5vw, 4.4rem);
    max-width: 16ch;
    margin-bottom: 1.4rem;
  }

  .hero__texto {
    max-width: 52ch;
    font-size: 1.15rem;
    opacity: 0.92;
    margin-bottom: 2.2rem;
  }

  .hero__acciones {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
