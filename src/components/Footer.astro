<footer class="pie">
  <div class="contenedor pie__interior">
    <span class="pie__marca">Apartamentos de Don Juan</span>
    <div class="pie__enlaces">
      <a href="https://instagram.com/apartamentos_dedonjuan">Instagram</a>
    </div>
    <small>© 2026 Apartamentos de Don Juan</small>
  </div>
</footer>

<style>
  .pie {
    background: var(--primario-oscuro);
    color: var(--claro);
    padding-block: 2.2rem;
  }

  .pie__interior {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .pie__marca {
    font-family: var(--fuente-display);
    font-size: 1.15rem;
  }

  .pie__enlaces {
    display: flex;
    gap: 1.4rem;
  }

  .pie__enlaces a {
    text-decoration: none;
    opacity: 0.85;
    font-size: 0.95rem;
  }

  .pie__enlaces a:hover {
    opacity: 1;
    text-decoration: underline;
  }

  small {
    opacity: 0.6;
  }
</style>
