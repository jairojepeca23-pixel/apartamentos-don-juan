---
interface Props {
  slug: string;
  number: number;
  name: string;
  shortDescription: string;
  capacity: number;
  highlights: string[];
  images?: string[];
}

const { slug, number, name, shortDescription, capacity, highlights, images = [] } = Astro.props;
---

<a class="tarjeta" href={`/apartamentos/${slug}/`}>
  {images.length > 0 ? (
    <img class="tarjeta__foto" src={images[0]} alt={`Foto de ${name}`} loading="lazy" width="600" height="450" />
  ) : (
    <div class={`tarjeta__marcador tarjeta__marcador--${number}`} aria-hidden="true">
      <span>{name}</span>
    </div>
  )}
  <div class="tarjeta__cuerpo">
    <h3>{name}</h3>
    <p class="tarjeta__resumen">{shortDescription}</p>
    <ul class="tarjeta__chips" aria-label="Comodidades destacadas">
      {highlights.slice(0, 4).map((item) => (
        <li>{item}</li>
      ))}
    </ul>
    <div class="tarjeta__pie">
      <span class="tarjeta__ver">Ver apartamento →</span>
      {capacity > 0 && (
        <span class="tarjeta__capacidad">Hasta {capacity} personas</span>
      )}
    </div>
  </div>
</a>

<style>
  .tarjeta {
    background: #fff;
    border-radius: var(--radio);
    overflow: hidden;
    box-shadow: 0 1px 4px #1c221914;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .tarjeta:hover,
  .tarjeta:focus-visible {
    transform: translateY(-4px);
    box-shadow: 0 10px 24px #1c221929;
  }

  .tarjeta:focus-visible {
    outline: 3px solid var(--acento);
    outline-offset: 2px;
  }

  .tarjeta:hover .tarjeta__ver {
    color: var(--acento);
  }

  .tarjeta__marcador {
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    color: var(--claro);
    font-family: var(--fuente-display);
    font-size: 1.3rem;
  }

  .tarjeta__foto {
    aspect-ratio: 4 / 3;
    width: 100%;
    object-fit: cover;
  }

  .tarjeta__marcador--1 {
    background: linear-gradient(140deg, var(--primario), var(--neutro));
  }

  .tarjeta__marcador--2 {
    background: linear-gradient(140deg, var(--neutro), var(--acento));
  }

  .tarjeta__marcador--3 {
    background: linear-gradient(140deg, var(--primario-oscuro), var(--primario));
  }

  .tarjeta__cuerpo {
    padding: 1.3rem 1.4rem 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .tarjeta__cuerpo h3 {
    font-size: 1.35rem;
    margin-bottom: 0.4rem;
  }

  .tarjeta__resumen {
    margin-bottom: 1rem;
  }

  .tarjeta__chips {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: auto;
  }

  .tarjeta__chips li {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--primario);
    background: var(--claro);
    border: 1px solid #23211c1f;
    border-radius: 999px;
    padding: 0.22rem 0.7rem;
    white-space: nowrap;
  }

  .tarjeta__pie {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-top: 1rem;
    border-top: 1px solid rgb(28 34 25 / 0.1);
    padding-top: 0.8rem;
  }

  .tarjeta__ver {
    font-weight: 700;
    color: var(--primario);
    transition: color 0.15s ease;
  }

  .tarjeta__capacidad {
    font-size: 0.9rem;
    color: #1c2219a6;
  }
</style>
