---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ApartmentCard from "../components/ApartmentCard.astro";
import Divider from "../components/Divider.astro";
import Services from "../components/Services.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { apartamentos } from "../data/apartamentos";

const title = "Alojamiento en Almadén de la Plata (Sevilla)";
const description = "Tres apartamentos turísticos recién reformados en el centro de Almadén de la Plata, a menos de 65 km de Sevilla. Cocina equipada, aire acondicionado y patio. Reservas: 677 25 60 36.";
---

<Layout title={title} description={description}>
  <Header />
  <Hero />

  <Divider variant="dark" />

  <section id="apartamentos" class="seccion">
    <div class="contenedor">
      <p class="antetitulo">Alojamiento en el centro del pueblo</p>
      <h2 class="titulo-seccion">Nuestros apartamentos</h2>
      <div class="tarjetas">
        {apartamentos.map((apt) => (
          <ApartmentCard
            slug={apt.slug}
            number={apt.number}
            name={apt.name}
            shortDescription={apt.shortDescription}
            capacity={apt.capacity}
            highlights={apt.highlights}
            images={apt.images}
          />
        ))}
      </div>
    </div>
  </section>

  <Services />

  <Divider variant="light" />

  <About />

  <Divider variant="light" />

  <Contact />

  <Footer />
</Layout>

<style>
  .tarjetas {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.6rem;
  }
</style>
